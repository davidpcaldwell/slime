set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd -P)"

# Generate a deterministic Compose project name per workspace path.
# Write to repository root .env so compose variable resolution picks it up
# when using docker-compose.yaml from the project root.
PROJECT_ROOT="$(cd "${HERE}/.." && pwd -P)"
if command -v sha1sum >/dev/null 2>&1; then
	PROJECT_HASH="$(printf '%s' "${PROJECT_ROOT}" | sha1sum | cut -c1-10)"
elif command -v shasum >/dev/null 2>&1; then
	PROJECT_HASH="$(printf '%s' "${PROJECT_ROOT}" | shasum -a 1 | cut -c1-10)"
else
	echo "initializeCommand requires sha1sum or shasum to derive COMPOSE_PROJECT_NAME." >&2
	exit 1
fi
COMPOSE_PROJECT_NAME="slime-${PROJECT_HASH}"
printf 'COMPOSE_PROJECT_NAME=%s\n' "${COMPOSE_PROJECT_NAME}" > "${PROJECT_ROOT}/.env"
rm -f "${HERE}/.env"

# VS Code server updates stage into <commit>_<suffix> temporary directories.
# If dotfiles remain, devcontainer's internal "mv * && rmdir" can fail because
# '*' does not include dotfiles. Remove stale temp dirs before startup.
VSCODE_BIN_DIR="${HERE}/../local/docker/home/.vscode-server/bin"
if [ -d "${VSCODE_BIN_DIR}" ]; then
	find "${VSCODE_BIN_DIR}" -mindepth 1 -maxdepth 1 -type d -name '*_*' -exec rm -rf {} +
fi

# Webtop URL opening is handled by devcontainer port forwarding.
exit 0
