set -euo pipefail

TARGET_UID="$(id -u)"
TARGET_GID="$(id -g)"

if [ ! -d /slime/local ]; then
	exit 0
fi

# Ensure the mount root itself is writable by the devcontainer user.
sudo chown "${TARGET_UID}:${TARGET_GID}" /slime/local

# Keep startup cost low by only repairing root-owned entries.
sudo find /slime/local -xdev \( -uid 0 -o -gid 0 \) -exec chown "${TARGET_UID}:${TARGET_GID}" {} +
